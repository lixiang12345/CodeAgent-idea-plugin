{
  "schemaVersion": 1,
  "suite": "codeagent-repository-retrieval",
  "description": "Versioned retrieval goldens for the CodeAgent repository.",
  "engine": {
    "mode": "auto",
    "expandGraph": true,
    "diversify": true,
    "commitLimit": 500,
    "extraRoots": [
      { "name": "docs", "path": "docs", "kind": "docs" }
    ],
    "exclude": [
      "evaluation/**",
      "scripts/evaluate-retrieval.mjs",
      "build/**"
    ]
  },
  "thresholds": {
    "minPathAccuracy": 0.75,
    "minMeanRecallAtK": 0.9,
    "minMeanMrr": 0.65,
    "minSymbolAccuracy": 1,
    "maxMeanLatencyMs": 2500,
    "maxP95LatencyMs": 5000,
    "maxFullIndexMs": 10000,
    "maxIncrementalNoChangeMs": 10000,
    "maxIncrementalOneFileMs": 10000,
    "maxQualityDrop": 0.05,
    "maxLatencyMultiplier": 2,
    "latencyAllowanceMs": 250
  },
  "cases": [
    {
      "id": "conversation-sync-architecture",
      "category": "architecture",
      "query": "reconcile local and cloud conversations across devices with tombstones and retry",
      "expectPaths": ["main/src/main/kotlin/com/codeagent/plugin/conversation/CloudConversationSyncService.kt"],
      "topK": 8
    },
    {
      "id": "webview-bridge-architecture",
      "category": "architecture",
      "query": "handle versioned webview commands and emit complete application snapshots",
      "expectPaths": ["main/src/main/kotlin/com/codeagent/plugin/bridge/IdeBridge.kt"],
      "topK": 8
    },
    {
      "id": "context-runtime-architecture",
      "category": "architecture",
      "query": "start bundled Node ContextEngine sidecar and exchange JSON Lines requests",
      "expectPaths": ["main/src/main/kotlin/com/codeagent/plugin/context/ContextEngineClient.kt"],
      "topK": 8
    },
    {
      "id": "agent-approval-architecture",
      "category": "architecture",
      "query": "pause an agent tool call for user approval and resume after the decision",
      "expectPaths": ["main/src/main/kotlin/com/codeagent/plugin/agent/AgentOrchestrator.kt"],
      "topK": 8
    },
    {
      "id": "server-policy-architecture",
      "category": "architecture",
      "query": "compose server owned system policy with repository rules skills and mode instructions",
      "expectPaths": ["main/backend/src/prompt.mjs"],
      "topK": 8
    },
    {
      "id": "model-gateway-architecture",
      "category": "architecture",
      "query": "normalize OpenAI Responses and Anthropic streaming tool calls through one model gateway",
      "expectPaths": ["main/backend/src/model-gateway.mjs"],
      "topK": 8
    },
    {
      "id": "approval-symbol",
      "category": "symbol",
      "query": "AgentOrchestrator resolveApproval approved tool decision",
      "expectPaths": ["main/src/main/kotlin/com/codeagent/plugin/agent/AgentOrchestrator.kt"],
      "expectSymbols": ["resolveApproval"],
      "topK": 8
    },
    {
      "id": "extra-roots-symbol",
      "category": "symbol",
      "query": "rpcExtraRoots",
      "expectPaths": ["main/src/main/kotlin/com/codeagent/plugin/context/ContextEngineClient.kt"],
      "topK": 8
    },
    {
      "id": "retrieval-budget-symbol",
      "category": "symbol",
      "query": "retrievalBudgetForContextWindow reserved context tokens",
      "expectPaths": ["main/backend/src/context-policy.mjs"],
      "expectSymbols": ["retrievalBudgetForContextWindow"],
      "topK": 8
    },
    {
      "id": "model-signing-symbol",
      "category": "symbol",
      "query": "signAwsRequest Bedrock Converse request signature",
      "expectPaths": ["main/backend/src/model-gateway.mjs"],
      "expectSymbols": ["signAwsRequest"],
      "topK": 8
    },
    {
      "id": "context-watcher-history",
      "category": "git-history",
      "query": "commit history feat(context): watch multi-root workspaces incrementally",
      "expectPaths": [".git/commits/1d5af3e"],
      "pathPrefix": ".git/commits",
      "topK": 8
    },
    {
      "id": "kotlin-chunk-history",
      "category": "git-history",
      "query": "commit history fix(context): preserve indexed Kotlin class bodies",
      "expectPaths": [".git/commits/06fd8be"],
      "pathPrefix": ".git/commits",
      "topK": 8
    },
    {
      "id": "architecture-doc-multi-root",
      "category": "multi-root",
      "query": "system architecture component boundary JetBrains plugin local sidecar backend",
      "expectPaths": ["docs/ARCHITECTURE.md"],
      "pathPrefix": "docs",
      "topK": 8
    },
    {
      "id": "provider-flow-multi-root",
      "category": "multi-root",
      "query": "provider trust boundaries data flow local context cloud control plane",
      "expectPaths": ["docs/PROVIDER_AND_DATA_FLOW.md"],
      "pathPrefix": "docs",
      "topK": 8
    },
    {
      "id": "frontend-settings-architecture",
      "category": "architecture",
      "query": "render account services settings threads composer approvals and tool cards",
      "expectPaths": ["main/frontend/src/App.svelte"],
      "topK": 8
    },
    {
      "id": "workspace-rules-architecture",
      "category": "architecture",
      "query": "discover repository rules guidelines and skills selected for an agent run",
      "expectPaths": ["main/src/main/kotlin/com/codeagent/plugin/agent/WorkspaceCustomizationService.kt"],
      "topK": 8
    }
  ]
}
