HOST=127.0.0.1
PORT=8787
CODEAGENT_AUTH_TOKEN=replace-with-a-long-random-token
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5175,http://localhost:5175
MODEL=gpt-5.6-sol
MODEL_ENDPOINT=https://example-model-gateway.test

# Defining provider model lists enables the fixed multi-provider router.
OPENAI_BASE_URL=https://example-model-gateway.test
OPENAI_API_KEY=
OPENAI_MODELS=gpt-5.6-sol
ANTHROPIC_BASE_URL=https://example-model-gateway.test
ANTHROPIC_API_KEY=
ANTHROPIC_MODELS=claude-fable-5,claude-opus-4-8,claude-sonnet-5
GROK_BASE_URL=https://example-model-gateway.test
GROK_API_KEY=
GROK_MODELS=grok-4.5

# Native Anthropic only.
MODEL_MAX_OUTPUT_TOKENS=8192

# Legacy single-provider mode remains available when provider model lists are omitted.
# MODEL_PROVIDER=openai-compatible
# MODEL_API_KEY=
