HOST=127.0.0.1
PORT=8787
CODEAGENT_AUTH_TOKEN=replace-with-a-long-random-token
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5175,http://localhost:5175
MODEL=gpt-5.6-sol
MODEL_ENDPOINT=https://example-model-gateway.test

# Defining provider model lists enables the fixed multi-provider router.
OPENAI_BASE_URL=https://example-model-gateway.test
OPENAI_API_KEY=
OPENAI_MODELS=gpt-5.6-sol
ANTHROPIC_BASE_URL=https://example-model-gateway.test
ANTHROPIC_API_KEY=
ANTHROPIC_MODELS=claude-fable-5,claude-opus-4-8,claude-sonnet-5
GROK_BASE_URL=https://example-model-gateway.test
GROK_API_KEY=
GROK_MODELS=grok-4.5

# Native Anthropic only.
MODEL_MAX_OUTPUT_TOKENS=8192

# Legacy single-provider mode remains available when provider model lists are omitted.
# MODEL_PROVIDER=openai-compatible
# MODEL_API_KEY=

# Web search: choose Brave or a compatible custom POST endpoint.
# WEB_SEARCH_PROVIDER=brave
# WEB_SEARCH_API_KEY=
# WEB_SEARCH_ENDPOINT=https://api.search.brave.com/res/v1/web/search
#
# Custom endpoint contract:
#   POST WEB_SEARCH_ENDPOINT
#   Authorization: Bearer WEB_SEARCH_API_KEY (optional)
#   body: {"query":"...","limit":5}
#   response: {"results":[{"title":"...","url":"...","snippet":"..."}]}
# WEB_SEARCH_PROVIDER=custom
# WEB_SEARCH_ENDPOINT=
# WEB_SEARCH_API_KEY=
# WEB_SEARCH_API_KEY_HEADER=Authorization

# Read-only SaaS search adapters
# GITHUB_TOKEN=
# GITHUB_API_URL=https://api.github.com
#
# LINEAR_API_KEY=
# LINEAR_API_URL=https://api.linear.app/graphql
#
# NOTION_TOKEN=
# NOTION_API_URL=https://api.notion.com/v1
# NOTION_VERSION=2025-09-03
#
# JIRA_BASE_URL=https://your-site.atlassian.net
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# JIRA_BEARER_TOKEN=
#
# CONFLUENCE_BASE_URL=https://your-site.atlassian.net
# CONFLUENCE_EMAIL=
# CONFLUENCE_API_TOKEN=
# CONFLUENCE_BEARER_TOKEN=
#
# GLEAN_SEARCH_ENDPOINT=https://your-instance/rest/api/v1/search
# GLEAN_API_TOKEN=
#
# Supabase queries are GET-only and restricted to this table/view allowlist.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=
# SUPABASE_TABLES=issues,projects
# SUPABASE_SCHEMA=public
