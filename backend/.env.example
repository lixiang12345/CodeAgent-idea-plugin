HOST=127.0.0.1
PORT=8787
CODEAGENT_AUTH_TOKEN=replace-with-a-long-random-token
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5175,http://localhost:5175
MODEL_BASE_URL=https://gateway.example.com
MODEL_API_KEY=replace-with-the-unified-gateway-key

# GET MODEL_BASE_URL/v1/models must return protocol metadata for every model:
# openai-responses, anthropic-messages, or xai-responses.

# Alternatively, configure a fixed multi-provider allowlist. Each enabled provider
# must define its own Base URL, API key, and comma-separated model IDs.
# MODEL=gpt-5.6-sol
# CONTEXT_QUERY_MODEL=gpt-5.4-mini
# MODEL_MAX_OUTPUT_TOKENS=8192
# MODEL_STREAM_IDLE_TIMEOUT_MS=45000
# OPENAI_BASE_URL=https://gateway.example.com
# OPENAI_API_KEY=
# OPENAI_MODELS=gpt-5.6-sol
# OPENAI_INTERNAL_MODELS=gpt-5.4-mini
# GROK_BASE_URL=https://gateway.example.com
# GROK_API_KEY=
# GROK_MODELS=grok-4.5
# ANTHROPIC_BASE_URL=https://gateway.example.com
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODELS=claude-fable-5,claude-sonnet-5

# Public product infrastructure. Use production secrets and HTTPS outside local development.
DATABASE_URL=postgresql://codeagent:codeagent-local@127.0.0.1:5432/codeagent
DATABASE_SSL=false
OIDC_ISSUER=https://identity.example.com
OIDC_CLIENT_ID=codeagent-backend
OIDC_CLIENT_SECRET=replace-with-the-oidc-client-secret
OIDC_AUDIENCE=codeagent-api
PUBLIC_BASE_URL=http://127.0.0.1:8788
SESSION_SIGNING_KEY=replace-with-at-least-32-random-characters
# Managed Node runtime distribution. Use one source: inline JSON for small/private deployments,
# or an HTTPS URL that serves the same manifest schema for multi-platform releases.
# RUNTIME_MANIFEST_JSON={"version":1,"runtimes":[]}
RUNTIME_MANIFEST_URL=https://downloads.example.com/codeagent/runtime-manifest.json

# Web search: choose Brave or a compatible custom POST endpoint.
# WEB_SEARCH_PROVIDER=brave
# WEB_SEARCH_API_KEY=
# WEB_SEARCH_ENDPOINT=https://api.search.brave.com/res/v1/web/search
#
# Custom endpoint contract:
#   POST WEB_SEARCH_ENDPOINT
#   Authorization: Bearer WEB_SEARCH_API_KEY (optional)
#   body: {"query":"...","limit":5}
#   response: {"results":[{"title":"...","url":"...","snippet":"..."}]}
# WEB_SEARCH_PROVIDER=custom
# WEB_SEARCH_ENDPOINT=
# WEB_SEARCH_API_KEY=
# WEB_SEARCH_API_KEY_HEADER=Authorization

# SaaS integration adapters
# GitHub reads need repository Metadata, Issues, Pull requests, Contents, and Checks read access.
# github_manage needs Issues or Pull requests write access for issue/PR creation, comments,
# reviews, and reviewer requests. github_merge_pull_request needs Pull requests write access.
# Both write tools are approval-gated; merge also requires the exact approved PR head SHA.
# GITHUB_TOKEN=
# GITHUB_API_URL=https://api.github.com
#
# LINEAR_API_KEY=
# LINEAR_API_URL=https://api.linear.app/graphql
#
# NOTION_TOKEN=
# NOTION_API_URL=https://api.notion.com/v1
# NOTION_VERSION=2025-09-03
#
# JIRA_BASE_URL=https://your-site.atlassian.net
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# JIRA_BEARER_TOKEN=
#
# CONFLUENCE_BASE_URL=https://your-site.atlassian.net
# CONFLUENCE_EMAIL=
# CONFLUENCE_API_TOKEN=
# CONFLUENCE_BEARER_TOKEN=
#
# GLEAN_SEARCH_ENDPOINT=https://your-instance/rest/api/v1/search
# GLEAN_API_TOKEN=
#
# Supabase queries are GET-only and restricted to this table/view allowlist.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=
# SUPABASE_TABLES=issues,projects
# SUPABASE_SCHEMA=public
