{
  "openapi": "3.1.0",
  "info": {
    "title": "CodeAgent Backend API",
    "version": "0.6.0",
    "description": "Protocol version 1 API used by the CodeAgent IDEA capability gateway."
  },
  "servers": [
    { "url": "http://127.0.0.1:8787", "description": "Local development" }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Check service and protocol compatibility",
        "responses": {
          "200": {
            "description": "Backend health",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Health" } } }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "summary": "Read this API contract",
        "responses": { "200": { "description": "OpenAPI 3.1 document" } }
      }
    },
    "/v1/models": {
      "get": {
        "summary": "List the configured model allowlist",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Enabled models",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ModelList" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/runs": {
      "post": {
        "summary": "Start an agent run and stream normalized events",
        "description": "Use streaming fetch. The response contains named SSE events documented in CONTRACT.md.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RunRequest" } } }
        },
        "responses": {
          "200": {
            "description": "SSE stream. Events: run.started, turn.started, message.delta, assistant.completed, tool.request, tool.completed, run.completed, run.error.",
            "headers": {
              "X-CodeAgent-Run-Id": { "schema": { "type": "string", "format": "uuid" } }
            },
            "content": {
              "text/event-stream": {
                "schema": { "type": "string" },
                "example": "event: run.started\ndata: {\"runId\":\"00000000-0000-0000-0000-000000000000\",\"protocolVersion\":1,\"provider\":\"multi-provider\",\"model\":\"gpt-5.6-sol\"}\n\n"
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/runs/{runId}/tool-results": {
      "post": {
        "summary": "Resume a run with one local tool result",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/RunId" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ToolResult" } } }
        },
        "responses": {
          "202": {
            "description": "Result accepted",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Accepted" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/v1/runs/{runId}": {
      "delete": {
        "summary": "Cancel an active run",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/RunId" }],
        "responses": {
          "202": {
            "description": "Run cancelled",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Cancelled" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "parameters": {
      "RunId": {
        "name": "runId",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "Unauthorized": {
        "description": "Missing or invalid bearer token",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "NotFound": {
        "description": "Run not found",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    },
    "schemas": {
      "Health": {
        "type": "object",
        "required": ["ok", "service", "protocolVersion", "provider", "defaultModel"],
        "properties": {
          "ok": { "type": "boolean", "const": true },
          "service": { "type": "string", "const": "codeagent-backend" },
          "protocolVersion": { "type": "integer", "const": 1 },
          "provider": { "type": "string" },
          "defaultModel": { "type": "string" }
        }
      },
      "ModelList": {
        "type": "object",
        "required": ["object", "provider", "defaultModel", "data"],
        "properties": {
          "object": { "type": "string", "const": "list" },
          "provider": { "type": "string" },
          "defaultModel": { "type": "string" },
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Model" } }
        }
      },
      "Model": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "ownedBy": { "type": "string" }
        }
      },
      "RunRequest": {
        "type": "object",
        "required": ["mode", "messages", "tools", "workspace"],
        "properties": {
          "mode": { "type": "string", "enum": ["agent", "chat", "ask"] },
          "model": { "type": "string" },
          "messages": { "type": "array", "items": { "$ref": "#/components/schemas/Message" } },
          "tools": { "type": "array", "items": { "$ref": "#/components/schemas/ToolDefinition" } },
          "workspace": { "$ref": "#/components/schemas/Workspace" }
        },
        "additionalProperties": false
      },
      "Message": {
        "type": "object",
        "required": ["role"],
        "properties": {
          "role": { "type": "string", "enum": ["user", "assistant", "tool"] },
          "content": { "type": ["string", "null"] },
          "toolCallId": { "type": "string" }
        },
        "additionalProperties": false
      },
      "ToolDefinition": {
        "type": "object",
        "required": ["name", "description", "parameters"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "parameters": { "type": "object" }
        },
        "additionalProperties": false
      },
      "Workspace": {
        "type": "object",
        "properties": {
          "guidance": { "type": ["string", "null"] },
          "rules": { "type": "array", "items": { "$ref": "#/components/schemas/WorkspaceEntry" }, "default": [] },
          "skills": { "type": "array", "items": { "$ref": "#/components/schemas/WorkspaceEntry" }, "default": [] }
        },
        "additionalProperties": false
      },
      "WorkspaceEntry": {
        "type": "object",
        "required": ["name", "path", "content"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "content": { "type": "string" }
        },
        "additionalProperties": false
      },
      "ToolResult": {
        "type": "object",
        "required": ["toolCallId", "status"],
        "properties": {
          "toolCallId": { "type": "string" },
          "status": { "type": "string", "enum": ["completed", "failed", "rejected"] },
          "output": { "type": "string", "default": "" },
          "error": { "type": "string", "default": "" },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      },
      "Accepted": {
        "type": "object",
        "required": ["accepted"],
        "properties": { "accepted": { "type": "boolean", "const": true } }
      },
      "Cancelled": {
        "type": "object",
        "required": ["cancelled"],
        "properties": { "cancelled": { "type": "boolean", "const": true } }
      },
      "Error": {
        "type": "object",
        "required": ["error"],
        "properties": { "error": { "type": "string" } }
      }
    }
  }
}
