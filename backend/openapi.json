{
  "openapi": "3.1.0",
  "info": {
    "title": "CodeAgent Backend API",
    "version": "0.6.0",
    "description": "Protocol version 1 API used by the CodeAgent IDEA capability gateway."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current deployment"
    },
    {
      "url": "http://127.0.0.1:8787",
      "description": "Local development"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Check service and protocol compatibility",
        "responses": {
          "200": {
            "description": "Backend health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Health"
                }
              }
            }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "summary": "Read this API contract",
        "responses": {
          "200": {
            "description": "OpenAPI 3.1 document"
          }
        }
      }
    },
    "/docs": {
      "get": {
        "summary": "Open interactive API documentation",
        "responses": {
          "200": {
            "description": "Self-contained HTML documentation",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/v1/models": {
      "get": {
        "summary": "List the configured model allowlist",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Enabled models",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelList"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/tools": {
      "get": {
        "summary": "List backend-owned integration tools and configuration status",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Configured and unavailable backend tool capabilities",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendToolList"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/tools/{toolName}": {
      "post": {
        "summary": "Execute one configured backend-owned integration tool",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ToolName"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BackendToolExecutionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Real provider result normalized for the agent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendToolExecutionResult"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "502": {
            "description": "Configured provider failed or returned an invalid response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Tool exists but its backend configuration is unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/enhance": {
      "post": {
        "summary": "Rewrite a user prompt for the coding agent",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text"
                ],
                "properties": {
                  "text": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 12000
                  },
                  "mode": {
                    "type": "string",
                    "enum": [
                      "agent",
                      "chat",
                      "ask"
                    ]
                  },
                  "model": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Enhanced prompt",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "text"
                  ],
                  "properties": {
                    "text": {
                      "type": "string"
                    },
                    "model": {
                      "type": "string"
                    },
                    "provider": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/runs": {
      "post": {
        "summary": "Start an agent run and stream normalized events",
        "description": "Use streaming fetch. The response contains named SSE events documented in CONTRACT.md.",
        "x-codeagent-sse-events": {
          "run.started": {
            "$ref": "#/components/schemas/RunStartedEvent"
          },
          "turn.started": {
            "$ref": "#/components/schemas/TurnStartedEvent"
          },
          "message.delta": {
            "$ref": "#/components/schemas/MessageDeltaEvent"
          },
          "assistant.completed": {
            "$ref": "#/components/schemas/AssistantCompletedEvent"
          },
          "tool.request": {
            "$ref": "#/components/schemas/ToolRequestEvent"
          },
          "tool.completed": {
            "$ref": "#/components/schemas/ToolCompletedEvent"
          },
          "run.completed": {
            "$ref": "#/components/schemas/RunCompletedEvent"
          },
          "run.error": {
            "$ref": "#/components/schemas/RunErrorEvent"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSE stream. Events: run.started, turn.started, message.delta, assistant.completed, tool.request, tool.completed, run.completed, run.error.",
            "headers": {
              "X-CodeAgent-Run-Id": {
                "schema": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            },
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string",
                  "contentMediaType": "text/event-stream",
                  "description": "Named SSE blocks whose JSON data payload matches SseEventPayload."
                },
                "example": "event: run.started\ndata: {\"runId\":\"00000000-0000-0000-0000-000000000000\",\"protocolVersion\":1,\"provider\":\"multi-provider\",\"model\":\"gpt-5.6-sol\"}\n\n"
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/runs/{runId}/tool-results": {
      "post": {
        "summary": "Resume a run with one local tool result",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/RunId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ToolResult"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Result accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Accepted"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/v1/runs/{runId}": {
      "delete": {
        "summary": "Cancel an active run",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/RunId"
          }
        ],
        "responses": {
          "202": {
            "description": "Run cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cancelled"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "parameters": {
      "RunId": {
        "name": "runId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "ToolName": {
        "name": "toolName",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]+$"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing or invalid bearer token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Requested resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "Health": {
        "type": "object",
        "required": [
          "ok",
          "service",
          "protocolVersion",
          "provider",
          "defaultModel"
        ],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "service": {
            "type": "string",
            "const": "codeagent-backend"
          },
          "protocolVersion": {
            "type": "integer",
            "const": 1
          },
          "provider": {
            "type": "string"
          },
          "defaultModel": {
            "type": "string"
          }
        }
      },
      "ModelList": {
        "type": "object",
        "required": [
          "object",
          "provider",
          "defaultModel",
          "data"
        ],
        "properties": {
          "object": {
            "type": "string",
            "const": "list"
          },
          "provider": {
            "type": "string"
          },
          "defaultModel": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Model"
            }
          }
        }
      },
      "Model": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "ownedBy": {
            "type": "string"
          }
        }
      },
      "BackendToolList": {
        "type": "object",
        "required": [
          "object",
          "data"
        ],
        "properties": {
          "object": {
            "type": "string",
            "const": "list"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BackendToolCapability"
            }
          }
        }
      },
      "BackendToolCapability": {
        "type": "object",
        "required": [
          "name",
          "catalogId",
          "description",
          "parameters",
          "available",
          "requiredEnvironment"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "catalogId": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "parameters": {
            "type": "object"
          },
          "available": {
            "type": "boolean"
          },
          "unavailableReason": {
            "type": "string"
          },
          "requiredEnvironment": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      },
      "BackendToolExecutionRequest": {
        "type": "object",
        "required": [
          "arguments"
        ],
        "properties": {
          "arguments": {
            "type": "object"
          }
        },
        "additionalProperties": false
      },
      "BackendToolExecutionResult": {
        "type": "object",
        "required": [
          "output",
          "summary"
        ],
        "properties": {
          "output": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RunRequest": {
        "type": "object",
        "required": [
          "mode",
          "messages",
          "tools",
          "workspace"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "agent",
              "chat",
              "ask"
            ]
          },
          "model": {
            "type": "string"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Message"
            }
          },
          "tools": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ToolDefinition"
            }
          },
          "workspace": {
            "$ref": "#/components/schemas/Workspace"
          }
        },
        "additionalProperties": false
      },
      "Message": {
        "type": "object",
        "required": [
          "role"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      },
      "ToolDefinition": {
        "type": "object",
        "required": [
          "name",
          "description",
          "parameters"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "parameters": {
            "type": "object"
          }
        },
        "additionalProperties": false
      },
      "Workspace": {
        "type": "object",
        "properties": {
          "guidance": {
            "type": [
              "string",
              "null"
            ]
          },
          "rules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkspaceEntry"
            },
            "default": []
          },
          "skills": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkspaceEntry"
            },
            "default": []
          }
        },
        "additionalProperties": false
      },
      "WorkspaceEntry": {
        "type": "object",
        "required": [
          "name",
          "path",
          "content"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RunStartedEvent": {
        "type": "object",
        "required": [
          "runId",
          "protocolVersion",
          "provider",
          "model"
        ],
        "properties": {
          "runId": {
            "type": "string",
            "format": "uuid"
          },
          "protocolVersion": {
            "type": "integer",
            "const": 1
          },
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "TurnStartedEvent": {
        "type": "object",
        "required": [
          "turnIndex"
        ],
        "properties": {
          "turnIndex": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "MessageDeltaEvent": {
        "type": "object",
        "required": [
          "delta",
          "turnIndex"
        ],
        "properties": {
          "delta": {
            "type": "string"
          },
          "turnIndex": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "AssistantCompletedEvent": {
        "type": "object",
        "required": [
          "content",
          "turnIndex"
        ],
        "properties": {
          "content": {
            "type": [
              "string",
              "null"
            ]
          },
          "turnIndex": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "ToolCall": {
        "type": "object",
        "required": [
          "id",
          "name",
          "arguments"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "arguments": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ToolRequestEvent": {
        "type": "object",
        "required": [
          "call",
          "turnIndex"
        ],
        "properties": {
          "call": {
            "$ref": "#/components/schemas/ToolCall"
          },
          "turnIndex": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "ToolCompletedEvent": {
        "type": "object",
        "required": [
          "toolCallId",
          "status"
        ],
        "properties": {
          "toolCallId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "completed",
              "failed",
              "rejected"
            ]
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RunCompletedEvent": {
        "type": "object",
        "required": [
          "turnCount"
        ],
        "properties": {
          "turnCount": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      },
      "RunErrorEvent": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "SseEventPayload": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/RunStartedEvent"
          },
          {
            "$ref": "#/components/schemas/TurnStartedEvent"
          },
          {
            "$ref": "#/components/schemas/MessageDeltaEvent"
          },
          {
            "$ref": "#/components/schemas/AssistantCompletedEvent"
          },
          {
            "$ref": "#/components/schemas/ToolRequestEvent"
          },
          {
            "$ref": "#/components/schemas/ToolCompletedEvent"
          },
          {
            "$ref": "#/components/schemas/RunCompletedEvent"
          },
          {
            "$ref": "#/components/schemas/RunErrorEvent"
          }
        ]
      },
      "ToolResult": {
        "type": "object",
        "required": [
          "toolCallId",
          "status"
        ],
        "properties": {
          "toolCallId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "completed",
              "failed",
              "rejected"
            ]
          },
          "output": {
            "type": "string",
            "default": ""
          },
          "error": {
            "type": "string",
            "default": ""
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Accepted": {
        "type": "object",
        "required": [
          "accepted"
        ],
        "properties": {
          "accepted": {
            "type": "boolean",
            "const": true
          }
        }
      },
      "Cancelled": {
        "type": "object",
        "required": [
          "cancelled"
        ],
        "properties": {
          "cancelled": {
            "type": "boolean",
            "const": true
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}
