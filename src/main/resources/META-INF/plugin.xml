<idea-plugin>
    <id>com.codeagent.idea</id>
    <name>CodeAgent</name>
    <vendor url="https://github.com/lixiang12345">CodeAgent</vendor>

    <description><![CDATA[
        <p>CodeAgent is an IDE-native AI coding agent for JetBrains IDEs.</p>
        <p>It combines a separately deployed Agent backend with approval-controlled IDE capabilities and local project retrieval powered by ContextEngine.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <resource-bundle>messages.CodeAgentBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="CodeAgent"
                    anchor="right"
                    secondary="true"
                    factoryClass="com.codeagent.plugin.ui.CodeAgentToolWindowFactory"/>
        <notificationGroup id="CodeAgent"
                           displayType="BALLOON"
                           isLogByDefault="true"/>
    </extensions>

    <actions>
        <action id="CodeAgent.ShowToolWindow"
                class="com.codeagent.plugin.actions.ShowCodeAgentAction"
                text="Show CodeAgent"
                description="Open the CodeAgent tool window">
            <keyboard-shortcut keymap="$default" first-keystroke="control alt I"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta control I"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
